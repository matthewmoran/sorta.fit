# Sorta.Fit -- Environment Configuration
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.
# On macOS/Linux, restrict permissions: chmod 600 .env

# =============================================================================
# REQUIRED — Board Connection
# =============================================================================

# Which adapter to use: jira, linear, github-issues
BOARD_ADAPTER=jira

# Your board's domain (no protocol, no trailing slash)
# Jira:           mycompany.atlassian.net
# Linear:         api.linear.app
# GitHub Issues:  github.com
BOARD_DOMAIN=mycompany.atlassian.net

# API token for authenticating with the board
# Jira:           generate at https://id.atlassian.com/manage-profile/security/api-tokens
# Linear:         generate at Linear > Settings > API > Personal API keys
# GitHub Issues:  personal access token with repo scope (optional if `gh auth login` is configured)
BOARD_API_TOKEN=your-api-token-here

# The project key on your board
# Jira:           project key, e.g. PROJ
# Linear:         team key, e.g. ENG
# GitHub Issues:  owner/repo, e.g. acme/my-project
BOARD_PROJECT_KEY=PROJ

# =============================================================================
# OPTIONAL — Board Authentication
# =============================================================================

# Email address for board authentication (required for Jira only)
BOARD_EMAIL=you@example.com

# =============================================================================
# OPTIONAL — Target Repository
# =============================================================================

# Absolute path to the repository sorta.fit operates on.
# This allows sorta.fit to live outside the target project (e.g., ~/tools/sorta-fit).
# If not set, falls back to the git repo containing the current working directory.
# TARGET_REPO=/absolute/path/to/your/project

# =============================================================================
# OPTIONAL — Git
# =============================================================================

# Base branch for feature branches (default: main)
GIT_BASE_BRANCH=main

# Release branch for promotion PRs (empty = disabled)
# When set, the merge runner opens a PR from GIT_BASE_BRANCH → GIT_RELEASE_BRANCH after each feature merge
# GIT_RELEASE_BRANCH=release

# =============================================================================
# OPTIONAL — Runner Behavior
# =============================================================================

# Seconds between polling cycles (default: 3600 = 1 hour)
POLL_INTERVAL=3600

# Maximum cards per cycle for each runner
MAX_CARDS_REFINE=5
MAX_CARDS_ARCHITECT=5
MAX_CARDS_CODE=2
MAX_CARDS_REVIEW=10
MAX_CARDS_TRIAGE=5
MAX_CARDS_BOUNCE=10
MAX_CARDS_MERGE=10

# How many extra batches to fetch if all cards in a batch are skipped (default: 3)
MAX_SKIP_RETRIES=3

# Merge strategy for the merge runner: merge, squash, or rebase (default: merge)
MERGE_STRATEGY=merge

# Comma-separated list of runners to run in the polling loop
# Available: refine, architect, code, review, triage, bounce, merge, documenter
# Order matters — runners execute left to right. Prefer finishing in-progress work
# (merge, bounce, review) before starting new work (code, refine, architect).
# (default: refine,code)
RUNNERS_ENABLED=merge,bounce,review,code,refine,architect,triage,documenter

# Event logging: writes structured JSON events to .sorta/events.jsonl
# Set to "off" to disable event logging entirely (default: on)
EVENT_LOGGING=on

# =============================================================================
# OPTIONAL — GitHub App Authentication (bot identity for PRs/reviews)
# =============================================================================

# When configured, the system authenticates as a GitHub App (e.g., sorta-fit-bot)
# instead of your personal account. This allows the review runner to approve/reject
# PRs since you can't review your own PRs on GitHub.
# Leave empty to use default gh auth (personal account).
# GH_APP_ID=
# GH_APP_INSTALLATION_ID=
# GH_APP_PRIVATE_KEY_PATH=

# =============================================================================
# OPTIONAL — Claude Agent Configuration
# =============================================================================

# Default Claude Code agent for all runners (empty = use CLI default)
# References a pre-configured Claude Code agent by name (see `claude agent` docs)
CLAUDE_AGENT=opus-high

# Per-runner agent overrides (takes precedence over CLAUDE_AGENT)
# RUNNER_REFINE_AGENT=
# RUNNER_ARCHITECT_AGENT=
# RUNNER_CODE_AGENT=
# RUNNER_REVIEW_AGENT=
# RUNNER_TRIAGE_AGENT=
# RUNNER_DOCUMENTER_AGENT=
# RUNNER_RELEASE_NOTES_AGENT=

# =============================================================================
# OPTIONAL — Runner Lane Routing (status IDs from your board)
# =============================================================================

# Each runner reads cards FROM a board status and transitions them TO another.
# Values are real status IDs — run the setup wizard or board_discover to find them.
#   Jira:           numeric status IDs (e.g., 10000)
#   Linear:         UUID workflow state IDs (e.g., f2b1c3d4-5678-9abc-def0-1234567890ab)
#   GitHub Issues:  label names (e.g., status:todo)
# Leave TO empty to skip the transition (card stays in place).
# Note: adapter config keys (STATUS_*, TRANSITION_TO_*) use bash-safe versions of these
# IDs (special chars replaced with underscores). Run board_discover for both forms.

# Refine: pick up raw cards, write specs, move to refined
RUNNER_REFINE_FROM=10000
RUNNER_REFINE_TO=10070

# Architect: pick up refined cards, enrich with implementation plan, move to architected
RUNNER_ARCHITECT_FROM=10070
RUNNER_ARCHITECT_TO=10071

# Code: pick up refined cards, implement, open PR, move to review
RUNNER_CODE_FROM=10069
RUNNER_CODE_TO=10036

# Review: pick up cards with PRs, post review (default: don't move)
RUNNER_REVIEW_FROM=10036
RUNNER_REVIEW_TO=

# Max characters for PR diffs sent to review (default: 100000)
# Noise files (lock files, minified assets, source maps) are filtered before this limit.
# When a diff still exceeds the limit, whole files are dropped with a summary.
# REVIEW_MAX_DIFF_CHARS=100000

# Triage: pick up bugs, analyze, move to refined
RUNNER_TRIAGE_FROM=10000
RUNNER_TRIAGE_TO=10070

# Bounce: move rejected PRs back for rework
RUNNER_BOUNCE_FROM=10036
RUNNER_BOUNCE_TO=10069

# Max times a card can bounce before escalating to a human (default: 3)
MAX_BOUNCES=3

# Where to move cards that hit the bounce limit (empty = stays in place)
# RUNNER_BOUNCE_ESCALATE=

# Merge: merge approved PRs, transition card to done
RUNNER_MERGE_FROM=10036
RUNNER_MERGE_TO=10070

# Documenter: generate/update docs from card specs, open PR
# Default: picks up from Done, transitions back to Done
RUNNER_DOCUMENTER_FROM=10037
RUNNER_DOCUMENTER_TO=10037
MAX_CARDS_DOCUMENTER=5

# Directory for generated documentation (relative to repo root)
DOCS_DIR=docs

# How to organize docs: "feature" groups by overall feature
DOCS_ORGANIZE_BY=feature
